NumVector :: [Number]

EntityTag :: "Player" | "Enviorment"
Entity :: {
    name: String,
    tag: EntityTag,  
    pos: NumVector,
    size: NumVector 
}

Entity(String, EntityTag, NumVector, NumVector) :: Entity
Entity(*name, *tag, *pos, *size) {}

Level :: {name: String, entities: [Entity]}

Level(String, [Entity]) :: Level
Level(*name, *entities) {}
